{
 "category": "datagram",
 "name": "header",
 "note": "\u00a74. Reserved flag bits are sender-MUST-zero / receiver-MUST-ignore; decode of reserved bits set therefore succeeds. unknown_stream/oversize/bad_magic etc. are silent drops, never PROTOCOL_VIOLATION.",
 "cases": [
  {
   "label": "single_fragment_keyframe",
   "op": "encode",
   "input": {
    "flags_keyframe": true,
    "stream_id": 0,
    "frame_seq": 0,
    "frag_index": 0,
    "frag_count": 1,
    "payload": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
   },
   "expected": {
    "hex": "4c0300000000000000000001aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
   }
  },
  {
   "label": "first_of_three_keyframe",
   "op": "encode",
   "input": {
    "flags_keyframe": true,
    "stream_id": 0,
    "frame_seq": 0,
    "frag_index": 0,
    "frag_count": 3,
    "payload": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
   },
   "expected": {
    "hex": "4c0100000000000000000003bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
   }
  },
  {
   "label": "last_of_three_keyframe",
   "op": "encode",
   "input": {
    "flags_keyframe": true,
    "stream_id": 0,
    "frame_seq": 0,
    "frag_index": 2,
    "frag_count": 3,
    "payload": "cccccccccccccccc"
   },
   "expected": {
    "hex": "4c0300000000000000020003cccccccccccccccc"
   }
  },
  {
   "label": "max_size_payload",
   "op": "encode",
   "input": {
    "flags_keyframe": false,
    "stream_id": 0,
    "frame_seq": 41,
    "frag_index": 1,
    "frag_count": 4,
    "payload": ""
   },
   "expected": {
    "hex": ""
   }
  },
  {
   "label": "audio_frame",
   "op": "encode",
   "input": {
    "flags_keyframe": false,
    "stream_id": 1,
    "frame_seq": 7,
    "frag_index": 0,
    "frag_count": 1,
    "payload": ""
   },
   "expected": {
    "hex": ""
   }
  },
  {
   "label": "max_frame_seq_empty_payload",
   "op": "encode",
   "input": {
    "flags_keyframe": false,
    "stream_id": 0,
    "frame_seq": 4294967295,
    "frag_index": 0,
    "frag_count": 1,
    "payload": ""
   },
   "expected": {
    "hex": "4c020000ffffffff00000001"
   }
  },
  {
   "label": "valid_roundtrip",
   "op": "decode",
   "input": {
    "hex": "4c03000000000005000000010102"
   },
   "expected": {
    "ok": true,
    "header": {
     "flags_keyframe": true,
     "flags_last": true,
     "stream_id": 0,
     "frame_seq": 5,
     "frag_index": 0,
     "frag_count": 1,
     "payload_len": 2
    }
   }
  },
  {
   "label": "bad_magic",
   "op": "decode",
   "input": {
    "hex": "4d0200000000000000000001"
   },
   "expected": {
    "ok": false,
    "reason": "bad_magic"
   }
  },
  {
   "label": "frag_count_zero",
   "op": "decode",
   "input": {
    "hex": "4c0200000000000000000000"
   },
   "expected": {
    "ok": false,
    "reason": "frag_count_zero"
   }
  },
  {
   "label": "frag_index_range",
   "op": "decode",
   "input": {
    "hex": "4c0200000000000000030003"
   },
   "expected": {
    "ok": false,
    "reason": "frag_index_range"
   }
  },
  {
   "label": "last_flag_missing_on_last",
   "op": "decode",
   "input": {
    "hex": "4c0000000000000000020003"
   },
   "expected": {
    "ok": false,
    "reason": "last_fragment_mismatch"
   }
  },
  {
   "label": "last_flag_set_on_nonlast",
   "op": "decode",
   "input": {
    "hex": "4c0200000000000000000003"
   },
   "expected": {
    "ok": false,
    "reason": "last_fragment_mismatch"
   }
  },
  {
